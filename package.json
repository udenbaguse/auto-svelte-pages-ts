  "exports": {
    ".": "./src/generator.js"
  },
  "keywords": [
    "svelte",
    "vite",
    "multipage",
    "generator",
    "cli"
  ],
  "author": "Muhamad Syamsudin A.K.A @udenbaguse",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  }
