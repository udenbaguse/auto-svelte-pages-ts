{
  "name": "auto-svelte-pages-ts",
  "version": "1.0.1",
  "description": "Generate Svelte TypeScript entry/component files from HTML pages and sync Vite multi-page inputs.",
  "type": "module",
  "files": [
    "bin",
    "src",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
